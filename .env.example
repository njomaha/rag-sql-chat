# OpenAI
OPENAI_API_KEY=sk-...

# PostgreSQL (matches docker-compose.yml defaults)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb

# Embedding model (text-embedding-3-small is cost-effective; swap to text-embedding-ada-002 if preferred)
EMBEDDING_MODEL=text-embedding-3-small

# GPT model for answer generation
CHAT_MODEL=gpt-4o

# Number of similar chunks to retrieve for context
TOP_K=5
